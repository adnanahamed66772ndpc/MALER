<UserControl x:Class="MailerApp.Desktop.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <TextBlock Text="Dashboard" Style="{StaticResource PageTitle}"/>
        <TextBlock Foreground="{StaticResource TextMutedBrush}" Margin="0,-16,0,20" TextWrapping="Wrap">
            Campaign summary: sent, failed, and total. Select a campaign and export results to CSV.
        </TextBlock>
        <Border Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Button Grid.Row="0" Content="Refresh" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}"
                        HorizontalAlignment="Left" Margin="20,16,0,12"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding Campaigns}" SelectedItem="{Binding SelectedCampaign}"
                          Style="{StaticResource ModernDataGrid}" AutoGenerateColumns="False" IsReadOnly="True" MinHeight="260">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                        <DataGridTextColumn Header="Sent" Binding="{Binding SentCount}" Width="70"/>
                        <DataGridTextColumn Header="Failed" Binding="{Binding FailedCount}" Width="70"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalRecipients}" Width="70"/>
                    </DataGrid.Columns>
                </DataGrid>
                <Button Grid.Row="2" Content="Export selected to CSV" Command="{Binding ExportCommand}" Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Left" Margin="20,16,0,20"/>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
