<UserControl x:Class="MailerApp.Desktop.Views.TemplatesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0">
            <TextBlock Text="Templates" Style="{StaticResource PageTitle}"/>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <Button Content="New template" Command="{Binding NewCommand}" Style="{StaticResource PrimaryButton}" Margin="0,0,0,8"/>
                    <Button Content="Load all" Command="{Binding LoadCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,0,12"/>
                    <TextBlock Text="Select template" Style="{StaticResource FieldLabel}"/>
                    <ListBox ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate}" DisplayMemberPath="Name"
                             BorderThickness="0" Background="#f8fafc" Padding="8" MinHeight="120"/>
                </StackPanel>
            </Border>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="24,0,0,0">
            <TextBlock Text="Edit template" Style="{StaticResource PageTitle}"/>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Name" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    <TextBlock Text="Subject" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding EditSubject, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,12"/>
                    <TextBlock Text="Insert variable" Style="{StaticResource FieldLabel}"/>
                    <ItemsControl ItemsSource="{Binding Variables}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,8"
                                        Command="{Binding DataContext.InsertVariableCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Body (HTML)" Style="{StaticResource SectionTitle}"/>
                    <TextBox Text="{Binding EditBodyHtml, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="140" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16"/>
                    <Button Content="Preview" Command="{Binding PreviewCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                    <TextBlock Text="Preview subject" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="{Binding PreviewSubject}" Margin="0,0,0,8" TextWrapping="Wrap"/>
                    <TextBlock Text="Preview body" Style="{StaticResource FieldLabel}"/>
                    <TextBox Text="{Binding PreviewBody}" Style="{StaticResource ModernTextBox}" IsReadOnly="True"
                             AcceptsReturn="True" TextWrapping="Wrap" Height="80" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16"/>
                    <Button Content="Save template" Command="{Binding SaveCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Left"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</UserControl>
