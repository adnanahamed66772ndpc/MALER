<UserControl x:Class="MailerApp.Desktop.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Settings" Style="{StaticResource PageTitle}"/>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Updates" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Margin="0,0,0,8">
                        <Run Text="Current version: " Foreground="{StaticResource TextMutedBrush}"/>
                        <Run Text="{Binding CurrentVersion}" FontWeight="SemiBold"/>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Check for updates" Command="{Binding CheckForUpdatesCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
                        <Button Content="Download and install" Command="{Binding DownloadAndInstallCommand}" Style="{StaticResource PrimaryButton}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding UpdateStatusMessage}" TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding ReleaseNotesText}" TextWrapping="Wrap" Margin="0,4,0,0" Foreground="#444"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Suppression list (do-not-send)" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="Add an email to block from all campaigns." Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding NewSuppressionEmail, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,10,0"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding SuppressionReasons}" SelectedItem="{Binding NewSuppressionReason}" Style="{StaticResource ModernComboBox}" Width="130" Margin="0,0,10,0"/>
                        <Button Grid.Column="2" Content="Add" Command="{Binding AddSuppressionCommand}" Style="{StaticResource PrimaryButton}"/>
                    </Grid>
                    <Button Content="Refresh list" Command="{Binding LoadSuppressionCommand}" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" Margin="0,0,0,12"/>
                    <DataGrid ItemsSource="{Binding SuppressionList}" Style="{StaticResource ModernDataGrid}"
                              AutoGenerateColumns="False" IsReadOnly="True" MinHeight="140">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                            <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="110"/>
                            <DataGridTextColumn Header="Date" Binding="{Binding CreatedAt, StringFormat=\{0:g\}}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Compliance reminder" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="• Ensure every template includes an unsubscribe link (e.g. {{{{unsubscribe_url}}}})." TextWrapping="Wrap" Margin="0,0,0,8" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="• Configure SPF, DKIM, and DMARC for your sending domain to improve deliverability." TextWrapping="Wrap" Margin="0,0,0,8" Foreground="{StaticResource TextMutedBrush}"/>
                    <TextBlock Text="• Respect CAN-SPAM and GDPR: honor opt-outs and the suppression list." TextWrapping="Wrap" Foreground="{StaticResource TextMutedBrush}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
